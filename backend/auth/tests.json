{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/register",
      "body": {
        "username": "testuser99",
        "email": "testuser99@example.com",
        "password": "password123",
        "display_name": "Тест Юзер"
      },
      "expectedStatus": 201,
      "expectedBody": { "token": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Login with wrong password",
      "method": "POST",
      "path": "/login",
      "body": {
        "login": "testuser99@example.com",
        "password": "wrongpassword"
      },
      "expectedStatus": 401,
      "expectedBody": { "error": "string" },
      "bodyMatcher": "partial"
    },
    {
      "name": "Get me without token",
      "method": "GET",
      "path": "/me",
      "expectedStatus": 401,
      "expectedBody": { "error": "string" },
      "bodyMatcher": "partial"
    }
  ]
}
